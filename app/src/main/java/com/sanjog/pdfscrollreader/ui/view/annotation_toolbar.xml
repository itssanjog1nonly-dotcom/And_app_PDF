<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/annotation_toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="4dp"
    android:paddingVertical="8dp">

    <!-- Tools -->
    <ImageButton android:id="@+id/btn_tool_pen" style="@style/AnnotationToolbarButton" android:src="@android:drawable/ic_menu_edit" />
    <ImageButton android:id="@+id/btn_tool_highlighter" style="@style/AnnotationToolbarButton" android:src="@android:drawable/ic_menu_view" />
    <ImageButton android:id="@+id/btn_tool_eraser" style="@style/AnnotationToolbarButton" android:src="@android:drawable/ic_menu_delete" />
    <ImageButton android:id="@+id/btn_tool_rect" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_rectangle" />
    <ImageButton android:id="@+id/btn_tool_ellipse" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_circle" />
    <ImageButton android:id="@+id/btn_tool_select_tap" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_pointer" />
    <ImageButton android:id="@+id/btn_tool_select_marquee" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_selection_marquee" />
    <ImageButton android:id="@+id/btn_tool_select_lasso" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_lasso" />
    <ImageButton android:id="@+id/btn_tool_select_lasso_fill" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_lasso_fill" />

    <!-- Colors -->
    <HorizontalScrollView
        android:id="@+id/color_scroll_container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton android:id="@+id/btn_color_black" style="@style/AnnotationColorSwatch" android:backgroundTint="@android:color/black" />
            <ImageButton android:id="@+id/btn_color_red" style="@style/AnnotationColorSwatch" android:backgroundTint="@android:color/holo_red_light" />
            <ImageButton android:id="@+id/btn_color_blue" style="@style/AnnotationColorSwatch" android:backgroundTint="@android:color/holo_blue_light" />
            <ImageButton android:id="@+id/btn_color_green" style="@style/AnnotationColorSwatch" android:backgroundTint="@android:color/holo_green_light" />
            <ImageButton android:id="@+id/btn_color_white" style="@style/AnnotationColorSwatch" android:backgroundTint="@android:color/white" />
            <ImageButton android:id="@+id/btn_color_custom" style="@style/AnnotationColorSwatch" android:src="@android:drawable/ic_menu_gallery" app:tint="@color/white" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Width Controls Group -->
    <LinearLayout
        android:id="@+id/width_controls_group"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P:" android:textColor="@color/white" android:textSize="12sp"/>
        <SeekBar android:id="@+id/seekbar_pen_width" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="50" android:min="2" android:progress="8"/>
        <EditText android:id="@+id/tv_pen_width_value" android:layout_width="28dp" android:layout_height="wrap_content" android:text="8" android:textColor="@color/white" android:textSize="14sp" android:background="@android:color/transparent" android:inputType="number" android:imeOptions="actionDone" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="H:" android:textColor="@color/white" android:textSize="12sp" android:layout_marginStart="4dp"/>
        <SeekBar android:id="@+id/seekbar_highlighter_width" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="80" android:min="10" android:progress="24"/>
        <EditText android:id="@+id/tv_highlighter_width_value" android:layout_width="28dp" android:layout_height="wrap_content" android:text="24" android:textColor="@color/white" android:textSize="14sp" android:background="@android:color/transparent" android:inputType="number" android:imeOptions="actionDone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_fill_alpha"
        android:layout_width="110dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:paddingHorizontal="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F:" android:textColor="@color/white" android:textSize="12sp"/>
        <SeekBar android:id="@+id/seekbar_fill_alpha" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="255" android:progress="0"/>
        <TextView android:id="@+id/tv_fill_alpha_value" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0%" android:textColor="@color/white" android:textSize="14sp" android:gravity="center"/>
    </LinearLayout>

    <!-- Actions -->
    <ImageButton android:id="@+id/btn_undo" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_undo" />
    <ImageButton android:id="@+id/btn_delete_selection" style="@style/AnnotationToolbarButton" android:src="@android:drawable/ic_menu_delete" app:tint="#FFFF5252" android:visibility="gone" />
    <ImageButton android:id="@+id/btn_redo" style="@style/AnnotationToolbarButton" android:src="@drawable/ic_redo" />
    <ImageButton android:id="@+id/btn_clear_all" style="@style/AnnotationToolbarButton" android:src="@android:drawable/ic_input_delete" />
    <ImageButton android:id="@+id/btn_exit_annotation" style="@style/AnnotationToolbarButton" android:src="@android:drawable/ic_menu_close_clear_cancel" />

    <!-- 2-Row Portrait Flow: wrap after tools -->
    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/toolbar_flow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:flow_wrapMode="aligned"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalGap="0dp"
        app:flow_verticalGap="8dp"
        app:flow_maxElementsWrap="9"
        app:constraint_referenced_ids="btn_tool_pen,btn_tool_highlighter,btn_tool_eraser,btn_tool_rect,btn_tool_ellipse,btn_tool_select_tap,btn_tool_select_marquee,btn_tool_select_lasso,btn_tool_select_lasso_fill,color_scroll_container,width_controls_group,layout_fill_alpha,btn_undo,btn_delete_selection,btn_redo,btn_clear_all,btn_exit_annotation" />

</androidx.constraintlayout.widget.ConstraintLayout>
