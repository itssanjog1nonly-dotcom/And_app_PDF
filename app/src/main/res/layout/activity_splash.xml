<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_splash_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_aurora_dark"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/layout_splash_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.30">

        <ImageView
            android:id="@+id/iv_splash_logo"
            android:layout_width="800dp"
            android:layout_height="350dp"
            android:src="@drawable/app_logo"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:scaleX="0.92"
            android:scaleY="0.92"
            android:alpha="0" />

        <TextView
            android:id="@+id/tv_splash_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="PdfScrollReader"
            android:textColor="@color/white"
            android:textSize="38sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:alpha="0" />

        <TextView
            android:id="@+id/tv_splash_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Read • Mark • Flow"
            android:textColor="@color/colorAccentCyan"
            android:textSize="19sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.2"
            android:alpha="0" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
